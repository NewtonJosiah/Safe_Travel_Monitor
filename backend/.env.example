# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/safe-travel-monitor

# JWT (Must be at least 32 characters for production)
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRE=7d

# CORS
CLIENT_URL=http://localhost:3000
ANDROID_APP_ID=com.safetravelmonitor.app

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Firebase (Optional - for push notifications)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_email
