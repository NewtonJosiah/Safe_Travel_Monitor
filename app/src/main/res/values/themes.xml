<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SafeTravelMonitor" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/primary_foreground</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/secondary_foreground</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorError">@color/destructive</item>
        <item name="colorOnError">@color/destructive_foreground</item>

        <item name="android:statusBarColor">?attr/colorPrimary</item>

        <!-- Global Immersive Mode Theme Support -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.SafeTravelMonitor.Welcome" parent="Theme.SafeTravelMonitor">
        <item name="android:windowBackground">@drawable/splash_blue_gradient</item>
        <item name="android:statusBarColor">#4D86D1</item>
        <item name="android:navigationBarColor">#2D60A1</item>
    </style>
</resources>
